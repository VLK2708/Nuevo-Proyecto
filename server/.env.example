# Puerto donde corre el servidor
PORT=3001

# Cuenta de Gmail que ENVÍA el correo (remitente)
GMAIL_USER=tu_cuenta@gmail.com

# Contraseña de aplicación de Gmail (NO tu contraseña normal)
# Se genera en: https://myaccount.google.com/apppasswords
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# Correo que RECIBE los mensajes del formulario (destino/seguimiento)
CONTACT_TO=marcomafh@gmail.com

# Dominios permitidos a consumir esta API, separados por coma
# En local puedes dejarlo vacío o poner http://127.0.0.1:5500
ALLOWED_ORIGINS=https://tudominio.com,http://127.0.0.1:5500
